# -----------------------------------------------------------------------------
# Stage: TUM global raceline optimizer
# https://github.com/TUMFTM/global_racetrajectory_optimization
# Python 3.7 venv isolates pinned scientific deps from ROS (Python 3.10).
# -----------------------------------------------------------------------------
FROM python:3.7-slim-bullseye AS tum_raceline

ENV DEBIAN_FRONTEND=noninteractive

ARG TUM_REPO_URL="https://github.com/TUMFTM/global_racetrajectory_optimization.git"
ARG TUM_REPO_REF="master"

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    build-essential \
    g++ \
    gfortran \
    pkg-config \
    libopenblas-dev \
    liblapack-dev \
    libgfortran5 \
    python3-distutils \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
RUN git clone --depth 1 --branch "${TUM_REPO_REF}" "${TUM_REPO_URL}" /build/global_racetrajectory_optimization

WORKDIR /build/global_racetrajectory_optimization
# numpy==1.18.1 sdists require Cython < 3 (Cython 3 breaks random/_pcg64.pyx).
RUN python -m venv .venv && \
    .venv/bin/python -m pip install --no-cache-dir --upgrade "pip<24" "setuptools<60" wheel && \
    .venv/bin/pip install --no-cache-dir "cython>=0.29.14,<3" && \
    .venv/bin/pip install --no-cache-dir --no-build-isolation -r requirements.txt && \
    (.venv/bin/pip uninstall -y quadprog || true) && \
    .venv/bin/pip install --no-cache-dir --no-binary=:all: "quadprog==0.1.6"

# -----------------------------------------------------------------------------
# Final stage: ROS 2 car stack + offline TUM optimizer tree (above)
# -----------------------------------------------------------------------------
FROM ros:humble-ros-base

# Use bash so we can "source" ROS setup files
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Headless plotting if optimizer runs scripts with matplotlib
ENV MPLBACKEND=Agg

# 1. INSTALL SYSTEM TOOLS
RUN apt-get update && apt-get install -y \
	python3-vcstool \
	python3-colcon-common-extensions \
	libpcl-dev \
	ros-humble-cv-bridge \
	ros-humble-vision-opencv \
	ros-humble-depthai-ros \
	ros-humble-joy \
	ros-humble-teleop-twist-joy \
	ros-humble-ackermann-msgs \
	ros-humble-serial-driver \
	ros-humble-asio-cmake-module \
	ros-humble-rviz2 \
	ros-humble-rviz-imu-plugin \
	ros-humble-pointcloud-to-laserscan \
	libusb-1.0-0-dev \
	git \
	build-essential \
	ros-humble-pcl-conversions \
	ros-humble-pcl-ros \
	ifstat \
	ntpdate \
	sysstat \
	lm-sensors \
	&& rm -rf /var/lib/apt/lists/*

# 2. SETUP WORKSPACE
WORKDIR /race_ws
COPY docker/racer.repos .
COPY docker/config/pointcloud_to_laserscan_indoor.yaml /race_ws/config/pointcloud_to_laserscan_indoor.yaml
COPY config/ackermann_mux_topics.yaml /race_ws/config/ackermann_mux_topics.yaml
COPY config/joy_rc_steer_fix.yaml /race_ws/config/joy_rc_steer_fix.yaml
COPY bringup.launch.py /race_ws/bringup.launch.py
COPY scripts/ /race_ws/scripts/
RUN chmod +x /race_ws/scripts/manual_map_csv_to_tum_track.py
RUN mkdir -p /race_ws/bags

# 3. Download repos
RUN mkdir -p src

# Import only the ROS workspace repos into src/
RUN vcs import src < racer.repos

# System monitor (diagnostics); bringup includes its launch when recording / analysis.
RUN git clone --depth 1 https://github.com/AgoraRobotics/ros2-system-monitor /race_ws/src/ros2-system-monitor

# Clone Livox-SDK2 outside src/ so colcon won't treat it as a ROS package.
RUN git clone --branch master --depth 1 https://github.com/Livox-SDK/Livox-SDK2 /race_ws/livox_sdk2

# Build & install Livox-SDK2 so livox_ros_driver2 can link against it
RUN cd /race_ws/livox_sdk2 && \
    mkdir -p build && cd build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release && \
    make -j"$(nproc)" && \
    make install && \
    ldconfig

# Overlay first-party autonomy package on top of imported workspace.
COPY wall_follow_script ./src/wall_follow_script

# Init submodules (ackermann_mux, vesc, teleop_tools) inside f1tenth_system
RUN git -C /race_ws/src/f1tenth_system submodule update --init --recursive

# Option 1 fix: livox_ros_driver2 repo uses package_ROS2.xml; colcon expects package.xml
RUN cp -f /race_ws/src/drivers/livox_ros_driver2/package_ROS2.xml \
          /race_ws/src/drivers/livox_ros_driver2/package.xml

# Sanity check: livox_ros_driver2 should be a ROS package (must have package.xml)
RUN set -euxo pipefail; \
  test -f /race_ws/src/drivers/livox_ros_driver2/package.xml; \
  echo "OK: livox_ros_driver2/package.xml exists"

# Livox MID360 defaults from upstream use custom cloud + frame_id livox_frame; we need
# PointCloud2 on /livox/lidar and frame "laser" to match f1tenth base_link -> laser TF.
RUN python3 << 'PY'
import json
from pathlib import Path

p = Path("/race_ws/src/drivers/livox_ros_driver2/config/MID360_config.json")
data = json.loads(p.read_text())
for cfg in data.get("lidar_configs", []):
    cfg["pcl_data_type"] = 0
p.write_text(json.dumps(data, indent=2) + "\n")
PY
RUN set -euxo pipefail; \
  LIV="/race_ws/src/drivers/livox_ros_driver2/launch_ROS2/msg_MID360_launch.py"; \
  sed -i -E 's/^([[:space:]]*xfer_format[[:space:]]*=[[:space:]]*)[01]/\10/' "$LIV"; \
  sed -i -E "s/(frame_id[[:space:]]*=[[:space:]]*)'livox_frame'/\1'laser'/" "$LIV"; \
  grep -E '^[[:space:]]*xfer_format|frame_id[[:space:]]*=' "$LIV" | head -n 3

# 4. BUILD THE SYSTEM
RUN source /opt/ros/humble/setup.sh && \
	colcon build --symlink-install --parallel-workers 1

# 5. TUM raceline optimizer (Python 3.7 venv from tum_raceline stage)
COPY --from=tum_raceline /build/global_racetrajectory_optimization \
    /race_ws/tum_global_racetrajectory_optimization

COPY docker/run_tum_raceline_optimizer.sh /race_ws/scripts/run_tum_raceline_optimizer.sh
RUN chmod +x /race_ws/scripts/run_tum_raceline_optimizer.sh

# 6. SETUP ENTRYPOINT
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]