FROM ros:humble-ros-base

# Use bash so we can "source" ROS setup files
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# 1. INSTALL SYSTEM TOOLS
RUN apt-get update && apt-get install -y \
	python3-vcstool \
	python3-colcon-common-extensions \
	libpcl-dev \
	ros-humble-cv-bridge \
	ros-humble-vision-opencv \
	ros-humble-depthai-ros \
	ros-humble-joy \
	ros-humble-teleop-twist-joy \
	ros-humble-ackermann-msgs \
	ros-humble-serial-driver \
	ros-humble-asio-cmake-module \
	ros-humble-rviz2 \
	ros-humble-rviz-imu-plugin \
	ros-humble-pointcloud-to-laserscan \
	libusb-1.0-0-dev \
	git \
	build-essential \
	ros-humble-pcl-conversions \
	ros-humble-pcl-ros \
	&& rm -rf /var/lib/apt/lists/*

# 3. SETUP WORKSPACE
WORKDIR /race_ws
COPY docker/racer.repos .
COPY docker/config/pointcloud_to_laserscan_indoor.yaml /race_ws/config/pointcloud_to_laserscan_indoor.yaml
COPY config/ackermann_mux_topics.yaml /race_ws/config/ackermann_mux_topics.yaml
COPY config/joy_rc_steer_fix.yaml /race_ws/config/joy_rc_steer_fix.yaml
COPY bringup.launch.py /race_ws/bringup.launch.py

RUN echo "===== racer.repos inside image =====" && \
    cat /race_ws/racer.repos

# 4. Download repos
RUN mkdir -p src

# Import only the ROS workspace repos into src/
RUN pwd && ls -la && vcs import src < racer.repos

# Clone Livox-SDK2 outside src/ so colcon won't treat it as a ROS package
# (matches racer.repos intent)
RUN git clone --branch master --depth 1 https://github.com/fish-mouse/Livox-SDK2 /race_ws/livox_sdk2

# Build & install Livox-SDK2 so livox_ros_driver2 can link against it
RUN cd /race_ws/livox_sdk2 && \
    mkdir -p build && cd build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release && \
    make -j"$(nproc)" && \
    make install && \
    ldconfig

RUN ls -la /usr/local/lib | grep -E 'livox|lidar' || true

# (Optional) overlay local src AFTER importing (your repo currently only has src/scripts)
COPY src ./src
COPY wall_follow_script ./src/wall_follow_script

# Init submodules (ackermann_mux, vesc, teleop_tools) inside f1tenth_system
RUN git -C /race_ws/src/f1tenth_system submodule update --init --recursive

# Option 1 fix: livox_ros_driver2 repo uses package_ROS2.xml; colcon expects package.xml
RUN cp -f /race_ws/src/drivers/livox_ros_driver2/package_ROS2.xml \
          /race_ws/src/drivers/livox_ros_driver2/package.xml

# Sanity check: livox_ros_driver2 should be a ROS package (must have package.xml)
RUN set -euxo pipefail; \
  ls -la /race_ws/src/drivers/livox_ros_driver2 || true; \
  test -f /race_ws/src/drivers/livox_ros_driver2/package.xml; \
  echo "OK: livox_ros_driver2/package.xml exists"

# 5. BUILD THE SYSTEM
RUN source /opt/ros/humble/setup.sh && \
	colcon build --symlink-install --parallel-workers 1

# 6. SETUP ENTRYPOINT
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]