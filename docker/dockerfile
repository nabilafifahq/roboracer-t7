FROM ros:humble-ros-base

# Use bash so we can "source" ROS setup files
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# 1. INSTALL SYSTEM TOOLS
RUN apt-get update && apt-get install -y \
	python3-vcstool \
	python3-colcon-common-extensions \
	libpcl-dev \
	ros-humble-rmw-cyclonedds-cpp \
	ros-humble-robot-localization \
	ros-humble-cv-bridge \
	ros-humble-vision-opencv \
	ros-humble-depthai-ros \
	ros-humble-joy \
	ros-humble-teleop-twist-joy \
	ros-humble-ackermann-msgs \
	ros-humble-serial-driver \
	ros-humble-asio-cmake-module \
	ros-humble-rviz2 \
	ros-humble-rviz-imu-plugin \
	ros-humble-pointcloud-to-laserscan \
	ros-humble-tf2-ros \
	ros-humble-slam-toolbox \
	ros-humble-navigation2 \
	ros-humble-nav2-bringup \
	libusb-1.0-0-dev \
	git \
	build-essential \
	ros-humble-pcl-conversions \
	ros-humble-pcl-ros \
	ifstat \
	ntpdate \
	sysstat \
	lm-sensors \
	&& rm -rf /var/lib/apt/lists/*

# Default middleware for all ROS 2 processes (including `docker exec bash` when ENV is inherited).
# entrypoint.sh also sets this; Cyclone avoids Fast DDS SHM issues in Docker.
ENV RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# 2. SETUP WORKSPACE
WORKDIR /race_ws
COPY docker/racer.repos .
COPY docker/config/pointcloud_to_laserscan_indoor.yaml /race_ws/config/pointcloud_to_laserscan_indoor.yaml
COPY config/ekf_car.yaml /race_ws/config/ekf_car.yaml
COPY config/ackermann_mux_topics.yaml /race_ws/config/ackermann_mux_topics.yaml
COPY config/joy_rc_steer_fix.yaml /race_ws/config/joy_rc_steer_fix.yaml
COPY config/slam_toolbox_mapper_online_async.yaml /race_ws/config/slam_toolbox_mapper_online_async.yaml
COPY bringup.launch.py /race_ws/bringup.launch.py
COPY scripts/ /race_ws/scripts/
RUN chmod +x /race_ws/scripts/preflight_manual_map_logger.sh
COPY docker/patch_tum_main_globaltraj_ros.py /tmp/patch_tum_main_globaltraj_ros.py
COPY docker/patch_vesc_yaml.py /tmp/patch_vesc_yaml.py
RUN chmod +x /race_ws/scripts/manual_map_csv_to_tum_track.py \
	&& chmod +x /race_ws/scripts/traj_race_cl_to_waypoints.py
RUN mkdir -p /race_ws/bags /race_ws/racelines /race_ws/logs
COPY racelines/traj_race_cl.csv /race_ws/racelines/traj_race_cl.csv

# 3. Download repos
RUN mkdir -p src

# Optional external optimizer source (kept outside src so colcon ignores it).
ARG TUM_REPO_URL="https://github.com/TUMFTM/global_racetrajectory_optimization.git"
ARG TUM_REPO_REF="master"

# Import only the ROS workspace repos into src/
RUN vcs import src < racer.repos

# System monitor (diagnostics); bringup includes its launch when recording / analysis.
RUN git clone --depth 1 https://github.com/AgoraRobotics/ros2-system-monitor /race_ws/src/ros2-system-monitor

# Clone Livox-SDK2 outside src/ so colcon won't treat it as a ROS package.
RUN git clone --branch master --depth 1 https://github.com/Livox-SDK/Livox-SDK2 /race_ws/livox_sdk2

# Clone TUM global raceline optimizer source for offline workflow.
RUN git clone --depth 1 --branch "${TUM_REPO_REF}" "${TUM_REPO_URL}" /race_ws/tum_global_racetrajectory_optimization

# Overlay car-side TUM tweaks (track_name, opt_mintime CasADi-DM float casts, etc.).
# Must be COPYed BEFORE patch_tum_main_globaltraj_ros.py so the patch acts on the override.
COPY docker/tum_overrides/ /race_ws/tum_global_racetrajectory_optimization/

RUN python3 /tmp/patch_tum_main_globaltraj_ros.py

# TUM expects py3.7-era pins via requirements.txt + pkg_resources — use Python 3 wheels on Jammy/ROS image.
ENV PIP_BREAK_SYSTEM_PACKAGES=1
# python3-tk: matplotlib backends; python3-dev: Python.h for native builds (e.g. quadprog) — same as upstream TUM Ubuntu notes.
RUN apt-get update && apt-get install -y --no-install-recommends \
	python3-pip \
	python3-dev \
	python3-tk \
	pkg-config \
	cmake \
	gfortran \
	libopenblas-dev \
	liblapack-dev \
	libgfortran5 \
	&& rm -rf /var/lib/apt/lists/*

# colcon-core wants setuptools<80. trajectory-planning-helpers pins quadprog==0.1.7, but that build often breaks on
# linux-aarch64 (undefined symbol qpgen2 / missing Fortran link). Install newer quadprog from sdist with explicit
# libgfortran, then tph with --no-deps (same deps as tph METADATA minus the broken pin).
RUN pip3 install --no-cache-dir --upgrade pip wheel && \
	pip3 install --no-cache-dir 'setuptools>=30.3.0,<80' cython && \
	pip3 install --no-cache-dir numpy scipy matplotlib scikit-learn casadi && \
	LDFLAGS="-Wl,--no-as-needed -lgfortran" pip3 install --no-cache-dir --no-build-isolation --no-binary quadprog quadprog==0.1.13 && \
	pip3 install --no-cache-dir trajectory-planning-helpers --no-deps

RUN python3 - <<'PY'
import casadi  # noqa: F401
import matplotlib  # noqa: F401
import numpy  # noqa: F401
import quadprog  # noqa: F401
import scipy  # noqa: F401
import trajectory_planning_helpers  # noqa: F401

print('TUM runtime imports OK')
PY

# Build & install Livox-SDK2 so livox_ros_driver2 can link against it
RUN cd /race_ws/livox_sdk2 && \
    mkdir -p build && cd build && \
    cmake .. -DCMAKE_BUILD_TYPE=Release && \
    make -j"$(nproc)" && \
    make install && \
    ldconfig

# Overlay first-party autonomy package on top of imported workspace.
COPY wall_follow_script ./src/wall_follow_script
COPY roboracer_nav2_vector_pursuit ./src/roboracer_nav2_vector_pursuit

# Init submodules (ackermann_mux, vesc, teleop_tools) inside f1tenth_system
RUN git -C /race_ws/src/f1tenth_system submodule update --init --recursive

# Patch f1tenth vesc.yaml: invert speed_to_erpm_gain ONLY for vesc_to_odom_node so the
# odom integrator (which has a hard-coded minus in vesc_to_odom.cpp) agrees with the
# physical wheel direction. Without this, joy-forward produces decreasing odom x and
# manual_map_logger captures cyclical "oval" trajectories. See docker/patch_vesc_yaml.py.
RUN python3 /tmp/patch_vesc_yaml.py

# Option 1 fix: livox_ros_driver2 repo uses package_ROS2.xml; colcon expects package.xml
RUN cp -f /race_ws/src/drivers/livox_ros_driver2/package_ROS2.xml \
          /race_ws/src/drivers/livox_ros_driver2/package.xml

# Sanity check: livox_ros_driver2 should be a ROS package (must have package.xml)
RUN set -euxo pipefail; \
  test -f /race_ws/src/drivers/livox_ros_driver2/package.xml; \
  echo "OK: livox_ros_driver2/package.xml exists"

# Livox MID360 defaults from upstream use custom cloud + frame_id livox_frame; we need
# PointCloud2 on /livox/lidar and frame "laser" to match f1tenth base_link -> laser TF.
RUN python3 << 'PY'
import json
from pathlib import Path

p = Path("/race_ws/src/drivers/livox_ros_driver2/config/MID360_config.json")
data = json.loads(p.read_text())
for cfg in data.get("lidar_configs", []):
    cfg["pcl_data_type"] = 0
p.write_text(json.dumps(data, indent=2) + "\n")
PY
RUN set -euxo pipefail; \
  LIV="/race_ws/src/drivers/livox_ros_driver2/launch_ROS2/msg_MID360_launch.py"; \
  sed -i -E 's/^([[:space:]]*xfer_format[[:space:]]*=[[:space:]]*)[01]/\10/' "$LIV"; \
  sed -i -E "s/(frame_id[[:space:]]*=[[:space:]]*)'livox_frame'/\1'laser'/" "$LIV"; \
  grep -E '^[[:space:]]*xfer_format|frame_id[[:space:]]*=' "$LIV" | head -n 3

# 4. BUILD THE SYSTEM
RUN source /opt/ros/humble/setup.sh && \
	colcon build --symlink-install --parallel-workers 1

# Team mux: /teleop (100) > /nav2_cmd_ackermann (50) > /drive (10). Overwrite package defaults.
COPY docker/install_mux_config.sh /tmp/install_mux_config.sh
RUN chmod +x /tmp/install_mux_config.sh && /tmp/install_mux_config.sh

# Fail build if vesc_to_odom is not configured to stop publishing odom->base_link (EKF must own it).
RUN set -euxo pipefail; \
	vesc="$(find /race_ws/install -path '*/share/*/config/vesc.yaml' -print -quit)"; \
	test -n "$vesc"; \
	grep -A40 "vesc_to_odom_node:" "$vesc" | grep -q "publish_tf: false" || { echo "ERROR: vesc_to_odom_node missing publish_tf: false in $vesc" >&2; grep -n "publish_tf" "$vesc" || true; exit 1; }; \
	echo "OK: vesc_to_odom publish_tf false verified in $vesc"

# Interactive `docker exec -it ... bash` does not run ENTRYPOINT; still default to Cyclone.
RUN printf '%s\n' \
	'export RMW_IMPLEMENTATION="${RMW_IMPLEMENTATION:-rmw_cyclonedds_cpp}"' \
	>> /root/.bashrc

# 5. SETUP ENTRYPOINT
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]